{
  "theme": "base",
  "look": "classic",
  "fontFamily": "Helvetica, Arial, sans-serif",
  "themeVariables": {
    "background": "#ffffff",
    "primaryColor": "#f5f5f4",
    "primaryTextColor": "#1c1917",
    "primaryBorderColor": "#57534e",
    "lineColor": "#57534e",
    "secondaryColor": "#fafaf9",
    "secondaryTextColor": "#1c1917",
    "secondaryBorderColor": "#78716c",
    "tertiaryColor": "#e7e5e4",
    "tertiaryTextColor": "#1c1917",
    "tertiaryBorderColor": "#78716c",
    "clusterBkg": "#f5f5f4",
    "clusterBorder": "#78716c",
    "edgeLabelBackground": "#fafaf9",
    "mainBkg": "#ffffff"
  },
  "flowchart": {
    "defaultRenderer": "elk",
    "htmlLabels": false,
    "curve": "linear",
    "nodeSpacing": 40,
    "rankSpacing": 48,
    "padding": 16
  },
  "sequence": {
    "mirrorActors": false,
    "wrap": true
  }
}
