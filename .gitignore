.DS_Store
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
dist/
.tmp-package/

# Generated outputs from local document runs
full/
tracking/
inputs/
report-body/

.venv
node_modules/

# Keep CI fixtures tracked even if a global ignore rule excludes tests/
!tests/
!tests/fixtures/
!tests/fixtures/document-writer/
!tests/fixtures/document-writer/report-body/
!tests/fixtures/document-writer/report-body/*.md
